<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" prefHeight="374.0" prefWidth="598.0" spacing="10.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <Label styleClass="title" text="Update inventory count">
         <VBox.margin>
            <Insets />
         </VBox.margin>
      </Label>
      <HBox maxHeight="50.0" maxWidth="1.7976931348623157E308" spacing="10.0" VBox.vgrow="ALWAYS">
         <children>
            <ToggleButton maxHeight="1.7976931348623157E308" maxWidth="150.0" mnemonicParsing="false" text="Add" HBox.hgrow="ALWAYS">
               <graphic>
                  <FontIcon iconLiteral="fltfal-add-24" iconSize="24" wrappingWidth="32.0" />
               </graphic>
               <styleClass>
                  <String fx:value="xl-label" />
                  <String fx:value="mode-picker-add" />
                  <String fx:value="mode-picker" />
               </styleClass>
            </ToggleButton>
            <ToggleButton maxHeight="1.7976931348623157E308" maxWidth="150.0" mnemonicParsing="false" text="Subtract" HBox.hgrow="ALWAYS">
               <graphic>
                  <FontIcon iconLiteral="fltfmz-minimize-24" iconSize="24" wrappingWidth="32.0" />
               </graphic>
               <styleClass>
                  <String fx:value="xl-label" />
                  <String fx:value="mode-picker" />
                  <String fx:value="mode-picker-subtract" />
               </styleClass>
            </ToggleButton>
            <ToggleButton maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Override" HBox.hgrow="ALWAYS">
               <graphic>
                  <FontIcon iconLiteral="fltfal-edit-settings-24" iconSize="24" wrappingWidth="32.0" />
               </graphic>
               <styleClass>
                  <String fx:value="xl-label" />
                  <String fx:value="mode-picker" />
                  <String fx:value="mode-picker-override" />
               </styleClass>
            </ToggleButton>
         </children>
      </HBox>
      <Label maxWidth="1.7976931348623157E308" styleClass="text-container" text="This should contain an explanation of the currently selected mode." wrapText="true">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <font>
            <Font size="14.0" />
         </font>
      </Label>
      <Separator maxHeight="1.7976931348623157E308" orientation="VERTICAL" visible="false" VBox.vgrow="ALWAYS" />
      <Spinner editable="true" maxHeight="75.0" maxWidth="1.7976931348623157E308" styleClass="update-inventory-spinner" VBox.vgrow="ALWAYS" />
