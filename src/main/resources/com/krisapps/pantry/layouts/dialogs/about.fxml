<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" spacing="10.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>
    <children>
        <ImageView fitHeight="250.0" fitWidth="250.0" preserveRatio="true">
            <image>
                <Image url="@../../icons/krisapps_productivity_suite.png" />
            </image>
        </ImageView>
        <VBox spacing="5.0">
            <children>
                <Label fx:id="primaryLabel" alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="title" text="KrisApps Pantry" />
                <Label fx:id="versionLabel" alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefWidth="427.0" styleClass="medium-label" text="Pantry v0.X.X • Part of KrisApps Productivity Suite." wrapText="true" />
            </children>
        </VBox>
        <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" VBox.vgrow="ALWAYS">
            <children>
                <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" spacing="20.0" />
                <HBox alignment="CENTER">
                    <children>
                        <Label fx:id="copyrightLabel" alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="medium-label" text="© 2026 KrisApps. All rights reserved." wrapText="true" />
                        <Label maxWidth="1.7976931348623157E308" text=" • " HBox.hgrow="NEVER" />
                        <Hyperlink fx:id="githubLink" alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="medium-label" text="GitHub repository">
                            <HBox.margin>
                                <Insets />
                            </HBox.margin>
                        </Hyperlink>
                    </children>
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </HBox>
            </children>
            <VBox.margin>
                <Insets />
            </VBox.margin>
        </VBox>
    </children>
    <stylesheets>
        <URL value="@../../stylesheets/core-ui.css" />
        <URL value="@../../stylesheets/main.css" />
    </stylesheets>
</VBox>
